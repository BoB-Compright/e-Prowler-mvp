# 인프라 보안 점검 도구 - 환경 변수 설정

# ============================================
# Claude API 설정
# ============================================
# https://console.anthropic.com 에서 발급 받기
ANTHROPIC_API_KEY=sk-ant-...

# Claude 분석 단계 실행 여부 (true/false, 기본값: false)
# 점검 항목마다 실제 API 호출이 발생해 토큰이 소모되므로, 평소 개발/UI 테스트 중에는
# false로 꺼두고 실제 데모/테스트 직전에만 true로 켜서 사용하세요.
CLAUDE_ANALYSIS_ENABLED=false

# ============================================
# 암호화 키 (AES-256)
# ============================================
# 생성 방법:
# python -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
#
# 중요: 이 키는 노트북에만 존재해야 합니다.
#      분실하면 저장된 암호화 데이터 복구 불가능합니다.
#      정기적으로 백업하세요.
INFRA_SECURITY_MASTER_KEY=<생성된 AES-256 키를 여기에 붙여넣기>

# ============================================
# 초기 관리자 계정 (인증)
# ============================================
# 서버 최초 기동 시(계정이 하나도 없을 때) 딱 한 번만 이 값으로 관리자 계정을
# 생성한다(멱등 — 이미 계정이 있으면 아무 동작도 하지 않는다). 자세한 내용은
# docs/adr/0001-authentication-local-accounts.md, README의
# "로그인 계정 (인증)" 절 참고.
AUTH_ADMIN_USERNAME=admin
AUTH_ADMIN_PASSWORD=<초기 비밀번호를 여기에>

# ============================================
# 데이터베이스 설정
# ============================================
# SQLite 파일 경로 (./data/infra_security.db)
# 환경변수로는 설정하지 않음 (파일 기반)

# ============================================
# 공유 링크 고정 베이스 URL (선택사항)
# ============================================
# PM 공유 링크(복사·QR·메일 본문)에 쓸 고정 공개 주소이자, proxy가 "공유 전용"으로
# 잠글 공개 호스트. ngrok 고정 도메인을 넣는다. 설정하면 점검자가 localhost로
# 작업해도 링크가 이 주소로 만들어지고, 이 호스트로 들어온 요청은 /share·/api/share만
# 열리고 로그인·대시보드·내부 API는 404가 된다. 미설정 시 접속 주소를 그대로 사용.
#
# ★ 이 값은 build-time에 번들로 굳는다: 프로덕션(npm run start)에서는 이 값을 넣고
#   반드시 `npm run build`를 해야 게이트·링크가 동작한다(안 넣고 빌드하면 게이트 비활성,
#   도메인 변경 시 재빌드).
# 설정법: docs/ops/share-ngrok.md
# 예: SHARE_BASE_URL=https://myname.ngrok-free.app
SHARE_BASE_URL=

# ============================================
# NVD CVE API 설정 (선택사항)
# ============================================
# https://nvd.nist.gov/developers/start-here 에서 API 키 발급
# 없으면 로컬 캐시 데이터만 사용
NVD_API_KEY=

# ============================================
# 백업 설정
# ============================================
# 자동 백업 활성화 (true/false)
AUTO_BACKUP_ENABLED=true

# 백업 시간 (HH:MM, 24시간 형식)
AUTO_BACKUP_TIME=02:00

# 백업 저장 경로
BACKUP_PATH=./data/backups

# ============================================
# 로깅 설정
# ============================================
# 로그 레벨: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# 로그 파일 경로
LOG_FILE=./logs/app.log

# ============================================
# 서버 설정
# ============================================
# FastAPI 호스트
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# React 개발 서버 (docker-compose에서만 사용)
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=3000

# ============================================
# Ansible 설정
# ============================================
# Ansible 워커 수 (병렬도, 최대 5개)
ANSIBLE_WORKERS=5

# SSH 연결 타임아웃 (초)
SSH_TIMEOUT=300

# SSH 재시도 횟수
SSH_RETRY_COUNT=3

# SSH 재시도 간격 (초)
SSH_RETRY_INTERVAL=30

# ============================================
# 주의사항
# ============================================
# 1. 이 파일을 복사하여 .env 파일을 생성하세요
# 2. .env 파일은 절대 Git에 커밋하지 마세요 (.gitignore에 등록됨)
# 3. 암호화 키는 매우 중요합니다 - 안전한 장소에 백업하세요
# 4. 노트북을 분실하면 복구 불가능합니다
